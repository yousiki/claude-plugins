{
  "name": "bash-lsp",
  "version": "0.1.1",
  "description": "Bash language server.",
  "author": { "name": "yousiki" },
  "homepage": "https://github.com/yousiki/claude-plugins/tree/main/plugins/bash-lsp",
  "license": "MIT",
  "lspServers": {
    "bash": {
      "command": "${CLAUDE_PLUGIN_ROOT}/scripts/launch-bash-lsp.sh",
